{
  "name": "@ponlawatp/feature-books",
  "version": "0.1.0",
  "description": "Knowledge graph of feature business-logic and code fences, stored as an Obsidian vault — works with OpenCode and Claude Code",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "scripts",
    "skills",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "obsidian",
    "knowledge-graph",
    "architecture",
    "feature-books"
  ],
  "author": "Ponlawat <ponlawat_pa@maholan.co.th>",
  "license": "MIT",
  "dependencies": {
    "@opencode-ai/plugin": "^1.17.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "typescript": "^5.7.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PonlawatP/feature-books-plugin.git"
  },
  "bugs": {
    "url": "https://github.com/PonlawatP/feature-books-plugin/issues"
  },
  "homepage": "https://github.com/PonlawatP/feature-books-plugin#readme"
}
